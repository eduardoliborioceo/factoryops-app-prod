# Variáveis de ambiente para o coletor local (coletor.py / sincronizador.py)
# Copie este arquivo para .env e preencha os valores reais.
# O arquivo .env NUNCA deve ser commitado no repositório.

# String de conexão com o banco Railway (obtida no painel Railway > seu projeto > PostgreSQL > Connect)
DATABASE_URL=postgresql://postgres:SUA_SENHA@SEU_HOST.proxy.rlwy.net:PORTA/railway

# URL da API local do Input BI
VENTTOS_API_URL=http://SEU_IP_INTERNO:5000/api/producao

# URL base do servidor MES (usado pelo sincronizador para buscar dados via POST)
# Padrão: http://192.168.1.32 — altere se o IP do servidor MES for diferente
MES_URL=http://192.168.1.32

# URL pública do FactoryOps no Railway (sem barra no final)
RAILWAY_URL=https://web-production-457281.up.railway.app

# Chave secreta para autenticação do sincronizador automático
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
# Esta mesma chave deve ser configurada em SYNC_API_KEY no painel Railway
SYNC_API_KEY=

# Google Maps Platform API Key (necessária para Places Autocomplete nos locais de entrega)
# Crie em: console.cloud.google.com → APIs & Services → Credentials
# Ative: Maps JavaScript API + Places API
GOOGLE_MAPS_API_KEY=
